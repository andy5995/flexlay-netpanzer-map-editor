# Copy this file to .env and adjust values for your system.
#
# HOSTUID / HOSTGID: the UID and GID that should own files created inside
# the Docker container. Set these to your own user so build output is not
# owned by root.
#
#   HOSTUID=$(id -u)
#   HOSTGID=$(id -g)
#
HOSTUID=1000
HOSTGID=1000

# Version string used in the AppImage filename.
# e.g. netpanzer-editor-0.1-x86_64.AppImage
VERSION=0.1
