#!/usr/bin/env bash

set -e

HERE="$(readlink -f "$(dirname "$0")")"

# Bundle shared library deps (flexlay_wrap.so, netpanzer_wrap.so, and
# everything linuxdeploy copied) come from usr/lib/.
export LD_LIBRARY_PATH="$HERE/usr/lib:${LD_LIBRARY_PATH}"

# Ruby extension modules (.so) live in usr/lib/; Ruby library scripts live
# in the two subdirectories below.
export RUBYLIB="$HERE/usr/lib:$HERE/usr/share/netpanzer-editor/ruby:$HERE/usr/share/netpanzer-editor/netpanzer:${RUBYLIB}"

# Flexlay icons / gui.xml — resolved by the Ruby code via $flexlay_datadir.
export FLEXLAY_DATADIR="$HERE/usr/share/netpanzer-editor/data"

# Editor sprite data (netpanzersprites.xml, thumbnails/) bundled from netpanzer/.
export NETPANZER_EDITOR_DATADIR="$HERE/usr/share/netpanzer-editor/netpanzer"

# NETPANZER_DATADIR must point to the user's netpanzer game data (wads/,
# tiles, etc.).  Warn if unset rather than silently using the hardcoded
# fallback path from the original developer's machine.
if [ -z "$NETPANZER_DATADIR" ]; then
  echo "Warning: NETPANZER_DATADIR is not set." >&2
  echo "Set it to the path of your netpanzer game data, e.g.:" >&2
  echo "  NETPANZER_DATADIR=/usr/share/games/netpanzer $0" >&2
fi

exec ruby -w "$HERE/usr/share/netpanzer-editor/netpanzer/netpanzer.rb" "$@"
